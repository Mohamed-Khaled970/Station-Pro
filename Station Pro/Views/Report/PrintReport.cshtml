@model CompleteReportDto
@using Microsoft.Extensions.Localization
@using StationPro
@using StationPro.Infrastructure.Helpers
@inject IStringLocalizer<SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["PrintReport"];
    Layout = null;
    var selectedPeriod = ViewBag.SelectedPeriod ?? "today";
    var periodName = selectedPeriod switch
    {
        "today" => Localizer["Today"],
        "yesterday" => Localizer["Yesterday"],
        "week" => Localizer["Last7Days"],
        "month" => Localizer["Last30Days"],
        _ => Localizer["CustomPeriod"]
    };

    // FIX: Show report generation time in Egypt local time
    var nowEgypt = TimeZoneHelper.NowInEgypt();

    // Detect RTL for Arabic
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var htmlDir = isRtl ? "rtl" : "ltr";
    var htmlLang = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;

    // Duration formatter — always outputs HH:MM:SS (pure LTR numeric, no Arabic labels)
    // Avoids bidi scrambling of mixed Arabic + number strings like "س 31دقيقة0"
    string FormatDuration(TimeSpan t)
    {
        var h = (int)t.TotalHours;
        var m = t.Minutes;
        var s = t.Seconds;
        return $"{h:D2}:{m:D2}:{s:D2}";
    }
}

<!DOCTYPE html>
<html lang="@htmlLang" dir="@htmlDir">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Localizer["PrintReport"] - @periodName - @nowEgypt.ToString("MMM dd, yyyy")</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @@media print {
            body {
                print-color-adjust: exact;
                -webkit-print-color-adjust: exact;
            }

            .no-print {
                display: none !important;
            }

            .page-break {
                page-break-after: always;
            }

            table {
                page-break-inside: auto;
            }

            tr {
                page-break-inside: avoid;
                page-break-after: auto;
            }

            thead {
                display: table-header-group;
            }
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        .print-header {
            border-bottom: 3px solid #3b82f6;
            padding-bottom: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: linear-gradient(135deg, #f8fafc 0%, #e0f2fe 100%);
            border: 2px solid #bfdbfe;
            border-radius: 8px;
            padding: 1.5rem;
        }

        .device-row {
            border-bottom: 1px solid #e5e7eb;
        }

            .device-row:last-child {
                border-bottom: none;
            }

        /*
                 * ltr-value — forces numbers, times, dates, and currency to always
                 * render left-to-right even inside an RTL (Arabic) document.
                 * Without this, the browser's bidi algorithm scrambles mixed
                 * Arabic + numeric strings, e.g. "05:00 ص" → "ص 05:00"
                 * and "0س 30دقيقة" instead of "0س 30دقيقة".
                 */
        .ltr-value {
            direction: ltr;
            unicode-bidi: embed;
            display: inline-block;
        }

        /* RTL table alignment */
        [dir="rtl"] table th,
        [dir="rtl"] table td {
            text-align: right;
        }

        [dir="rtl"] .text-center th,
        [dir="rtl"] .text-center td {
            text-align: center;
        }

        /* Header right block flips to left in RTL */
        [dir="rtl"] .header-meta {
            text-align: left;
        }
    </style>
</head>
<body class="bg-white p-8">

    <!-- Print Button (hidden on print) -->
    <div class="no-print mb-4 flex justify-end gap-3">
        <button onclick="window.print()" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 flex items-center gap-2">
            <i class="fas fa-print"></i>
            @Localizer["PrintReportButton"]
        </button>
        <button onclick="window.close()" class="bg-gray-600 text-white px-6 py-2 rounded-lg hover:bg-gray-700 flex items-center gap-2">
            <i class="fas fa-times"></i>
            @Localizer["Close"]
        </button>
    </div>

    <div class="max-w-7xl mx-auto">

        <!-- Header -->
        <div class="print-header">
            <div class="flex justify-between items-start">
                <div>
                    <div class="flex items-center gap-3 mb-3">
                        <i class="fas fa-gamepad text-blue-600 text-4xl"></i>
                        <div>
                            <h1 class="text-3xl font-bold text-gray-900">@Localizer["StationPro"]</h1>
                            <p class="text-sm text-gray-500">demo.stationpro.com</p>
                        </div>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-800">@Localizer["FinancialReport"]</h2>
                    <p class="text-gray-600">@Localizer["Period"]: @periodName</p>
                </div>

                @* Header meta block — text-right in LTR, text-left in RTL *@
                <div class="header-meta @(isRtl ? "text-left" : "text-right")">
                    <p class="text-sm text-gray-500">@Localizer["ReportGenerated"]:</p>
                    <p class="font-semibold text-gray-900">
                        @* FIX: date wrapped in ltr-value to prevent MMM/dd flip *@
                        <span class="ltr-value">@nowEgypt.ToString("MMMM dd, yyyy")</span>
                    </p>
                    <p class="text-sm text-gray-500">
                        @* FIX: time wrapped in ltr-value to prevent "ص 05:00" scramble *@
                        <span class="ltr-value">@nowEgypt.ToString("hh:mm tt")</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Summary Statistics -->
        <div class="mb-8">
            <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                <i class="fas fa-chart-bar text-blue-600"></i>
                @Localizer["SummaryStatistics"]
            </h3>

            <div class="grid grid-cols-4 gap-4 mb-6">
                <div class="stat-card text-center">
                    <i class="fas fa-dollar-sign text-3xl text-green-600 mb-2"></i>
                    <div class="text-2xl font-bold text-gray-900">
                        <span class="ltr-value">EGP @Model.Summary.TotalRevenue.ToString("N2")</span>
                    </div>
                    <div class="text-sm text-gray-600 font-semibold mt-1">@Localizer["TotalRevenue"].ToString().ToUpper()</div>
                </div>
                <div class="stat-card text-center">
                    <i class="fas fa-clock text-3xl text-blue-600 mb-2"></i>
                    <div class="text-2xl font-bold text-gray-900">
                        <span class="ltr-value">@Model.Summary.TotalSessions</span>
                    </div>
                    <div class="text-sm text-gray-600 font-semibold mt-1">@Localizer["TotalSessions"].ToString().ToUpper()</div>
                </div>
                <div class="stat-card text-center">
                    <i class="fas fa-chart-line text-3xl text-purple-600 mb-2"></i>
                    <div class="text-2xl font-bold text-gray-900">
                        <span class="ltr-value">EGP @Model.Summary.AverageSessionRevenue.ToString("N2")</span>
                    </div>
                    <div class="text-sm text-gray-600 font-semibold mt-1">@Localizer["AvgSessionRevenue"].ToString().ToUpper()</div>
                </div>
                <div class="stat-card text-center">
                    <i class="fas fa-check-circle text-3xl text-orange-600 mb-2"></i>
                    <div class="text-2xl font-bold text-gray-900">
                        <span class="ltr-value">@Model.Summary.CompletedSessions</span>
                    </div>
                    <div class="text-sm text-gray-600 font-semibold mt-1">@Localizer["CompletedSessions"].ToString().ToUpper()</div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 text-sm">
                <div class="bg-gray-50 p-3 rounded-lg border border-gray-200">
                    <span class="text-gray-600">@Localizer["MostUsedDevice"]:</span>
                    <span class="font-bold text-gray-900 ml-2">@Model.Summary.MostUsedDevice</span>
                </div>
                <div class="bg-gray-50 p-3 rounded-lg border border-gray-200">
                    <span class="text-gray-600">@Localizer["ReportPeriod"]:</span>
                    @* FIX: period date range in ltr-value *@
                    <span class="font-bold text-gray-900 ml-2">
                        <span class="ltr-value">
                            @TimeZoneHelper.ToEgyptTime(Model.Summary.StartDate).ToString("MMM dd") -
                            @TimeZoneHelper.ToEgyptTime(Model.Summary.EndDate).ToString("MMM dd, yyyy")
                        </span>
                    </span>
                </div>
            </div>
        </div>

        <!-- Device Performance -->
        @if (Model.DevicePerformance.Any())
        {
            <div class="mb-8">
                <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                    <i class="fas fa-trophy text-yellow-500"></i>
                    @Localizer["DevicePerformance"]
                </h3>

                <table class="w-full border-collapse border border-gray-300">
                    <thead>
                        <tr class="bg-gray-100">
                            <th class="border border-gray-300 px-4 py-3 text-start font-semibold text-gray-700">@Localizer["Device"]</th>
                            <th class="border border-gray-300 px-4 py-3 text-center font-semibold text-gray-700">@Localizer["Type"]</th>
                            <th class="border border-gray-300 px-4 py-3 text-center font-semibold text-gray-700">@Localizer["Sessions"]</th>
                            <th class="border border-gray-300 px-4 py-3 text-center font-semibold text-gray-700">@Localizer["UsageTime"]</th>
                            <th class="border border-gray-300 px-4 py-3 text-center font-semibold text-gray-700">@Localizer["Utilization"]</th>
                            <th class="border border-gray-300 px-4 py-3 text-end font-semibold text-gray-700">@Localizer["Revenue"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var device in Model.DevicePerformance)
                        {
                            <tr class="device-row">
                                <td class="border border-gray-300 px-4 py-3 font-semibold text-gray-900">@device.DeviceName</td>
                                <td class="border border-gray-300 px-4 py-3 text-center text-gray-700">@device.DeviceType</td>
                                <td class="border border-gray-300 px-4 py-3 text-center font-semibold text-gray-900">
                                    <span class="ltr-value">@device.SessionCount</span>
                                </td>
                                <td class="border border-gray-300 px-4 py-3 text-center text-gray-700">
                                    @* FIX: FormatDuration outputs HH:MM:SS — pure numeric, no Arabic labels,
                            zero bidi scrambling. "س 31دقيقة0" is now "00:31:00" *@
                                    <span class="ltr-value font-mono">@FormatDuration(device.TotalUsageTime)</span>
                                </td>
                                <td class="border border-gray-300 px-4 py-3 text-center font-semibold text-blue-600">
                                    <span class="ltr-value">@device.UtilizationPercentage.ToString("N1")%</span>
                                </td>
                                <td class="border border-gray-300 px-4 py-3 text-end font-bold text-green-600">
                                    <span class="ltr-value">EGP @device.TotalRevenue.ToString("N2")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="bg-gray-100 font-bold">
                            <td colspan="2" class="border border-gray-300 px-4 py-3 text-end">@Localizer["TOTAL"]:</td>
                            <td class="border border-gray-300 px-4 py-3 text-center">
                                <span class="ltr-value">@Model.DevicePerformance.Sum(d => d.SessionCount)</span>
                            </td>
                            <td class="border border-gray-300 px-4 py-3 text-center">
                                @{
                                    var totalSpan = TimeSpan.FromMinutes(
                                    Model.DevicePerformance.Sum(d => d.TotalUsageTime.TotalMinutes));
                                }
                                @* FIX: FormatDuration — clean HH:MM:SS, no Arabic mixed labels *@
                                <span class="ltr-value font-mono">@FormatDuration(totalSpan)</span>
                            </td>
                            <td class="border border-gray-300 px-4 py-3"></td>
                            <td class="border border-gray-300 px-4 py-3 text-end text-green-600">
                                <span class="ltr-value">EGP @Model.DevicePerformance.Sum(d => d.TotalRevenue).ToString("N2")</span>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }

        <!-- Page Break for Print -->
        <div class="page-break"></div>

        <!-- Session Details -->
        @if (Model.Sessions.Any())
        {
            <div class="mb-8">
                <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                    <i class="fas fa-list text-blue-600"></i>
                    @Localizer["SessionDetails"] (@Model.Sessions.Count @Localizer["Sessions"])
                </h3>

                <table class="w-full border-collapse border border-gray-300 text-sm">
                    <thead>
                        <tr class="bg-gray-100">
                            <th class="border border-gray-300 px-3 py-2 text-start font-semibold text-gray-700">@Localizer["DateTime"]</th>
                            <th class="border border-gray-300 px-3 py-2 text-start font-semibold text-gray-700">@Localizer["Device"]</th>
                            <th class="border border-gray-300 px-3 py-2 text-start font-semibold text-gray-700">@Localizer["Customer"]</th>
                            <th class="border border-gray-300 px-3 py-2 text-center font-semibold text-gray-700">@Localizer["Duration"]</th>
                            <th class="border border-gray-300 px-3 py-2 text-center font-semibold text-gray-700">@Localizer["Rate"]</th>
                            <th class="border border-gray-300 px-3 py-2 text-end font-semibold text-gray-700">@Localizer["Total"]</th>
                            <th class="border border-gray-300 px-3 py-2 text-center font-semibold text-gray-700">@Localizer["Status"]</th>
                            <th class="border border-gray-300 px-3 py-2 text-center font-semibold text-gray-700">@Localizer["Payment"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model.Sessions)
                        {
                            @* FIX: Convert UTC StartTime to Egypt local time (UTC+2) *@
                            var egyptTime = TimeZoneHelper.ToEgyptTime(session.StartTime);
                            <tr>
                                <td class="border border-gray-300 px-3 py-2">
                                    @* FIX: date + time both wrapped in ltr-value *@
                                    <div class="font-semibold text-gray-900">
                                        <span class="ltr-value">@egyptTime.ToString("MMM dd, yyyy")</span>
                                    </div>
                                    <div class="text-xs text-gray-500">
                                        <span class="ltr-value">@egyptTime.ToString("hh:mm tt")</span>
                                    </div>
                                </td>
                                <td class="border border-gray-300 px-3 py-2">
                                    <div class="font-semibold text-gray-900">@session.DeviceName</div>
                                    <div class="text-xs text-gray-500">@session.DeviceType</div>
                                </td>
                                <td class="border border-gray-300 px-3 py-2 text-gray-700">
                                    @(session.CustomerName ?? Localizer["Guest"])
                                </td>
                                <td class="border border-gray-300 px-3 py-2 text-center font-mono">
                                    @* FIX: HH:MM:SS must always be LTR *@
                                    <span class="ltr-value">@session.DurationFormatted</span>
                                </td>
                                <td class="border border-gray-300 px-3 py-2 text-center text-gray-700">
                                    <span class="ltr-value">EGP @session.HourlyRate.ToString("N2")</span>
                                </td>
                                <td class="border border-gray-300 px-3 py-2 text-end font-bold text-green-600">
                                    <span class="ltr-value">EGP @session.TotalCost.ToString("N2")</span>
                                </td>
                                <td class="border border-gray-300 px-3 py-2 text-center">
                                    <span class="inline-block px-2 py-1 rounded text-xs font-semibold
                                        @(session.Status == "Completed" ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                                        @session.Status
                                    </span>
                                </td>
                                <td class="border border-gray-300 px-3 py-2 text-center text-gray-700">
                                    @session.PaymentMethod
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Footer -->
        <div class="mt-8 pt-4 border-t-2 border-gray-300 text-center text-sm text-gray-500">
            <p>@Localizer["ComputerGeneratedReport"]</p>
            <p>© <span class="ltr-value">@nowEgypt.Year</span> @Localizer["StationPro"] - @Localizer["CopyrightNotice"]</p>
        </div>

    </div>

    <script>
        // Auto-print dialog on load (optional)
        // window.onload = function() { window.print(); }
    </script>

</body>
</html>
