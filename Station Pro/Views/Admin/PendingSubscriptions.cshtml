@model List<StationPro.Application.DTOs.Subscriptions.PendingSubscriptionDto>
@{
    ViewData["Title"] = "Subscription Requests";
    Layout = null;  // ← isolated
    var filter = Context.Request.Query["filter"].ToString() is { Length: > 0 } f ? f : "all";
}

<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Subscription Requests — Station Pro Admin</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='90'>🛡️</text></svg>">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

        body {
            font-family: 'Inter', sans-serif;
        }

        .status-badge-pending {
            background: #fef3c7;
            color: #92400e;
        }

        .status-badge-approved {
            background: #d1fae5;
            color: #065f46;
        }

        .status-badge-rejected {
            background: #fee2e2;
            color: #991b1b;
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">

    <!-- Admin Navigation (same as Index) -->
    <nav class="bg-gradient-to-r from-slate-800 to-slate-900 shadow-lg sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo -->
                <div class="flex items-center space-x-3">
                    <div class="w-9 h-9 bg-blue-500 rounded-lg flex items-center justify-center">
                        <i class="fas fa-shield-alt text-white text-sm"></i>
                    </div>
                    <div>
                        <span class="text-white font-bold text-lg">Station Pro</span>
                        <span class="text-blue-400 text-xs font-medium ml-2 bg-blue-400/10 px-2 py-0.5 rounded-full border border-blue-400/30">Admin</span>
                    </div>
                </div>

                <!-- Nav Links -->
                <div class="hidden md:flex items-center space-x-1">
                    <a href="/Admin/Index"
                       class="px-4 py-2 rounded-lg text-slate-300 hover:text-white hover:bg-white/10 font-medium text-sm transition-all">
                        <i class="fas fa-chart-line mr-2 text-blue-400"></i>Dashboard
                    </a>
                    <a href="/Admin/PendingSubscriptions"
                       class="px-4 py-2 rounded-lg text-white bg-white/10 font-medium text-sm transition-all relative">
                        <i class="fas fa-clock mr-2 text-yellow-400"></i>Subscriptions
                        @{
                            var pendingCount = Model.Count(s => s.Status == "Pending");
                        }
                        @if (pendingCount > 0)
                        {
                            <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center">
                                @pendingCount
                            </span>
                        }
                    </a>
                </div>

                <!-- Admin info + Logout -->
                <div class="flex items-center space-x-3">
                    <div class="hidden md:flex items-center space-x-2 text-slate-300 text-sm">
                        <div class="w-8 h-8 bg-blue-500/20 border border-blue-400/30 rounded-full flex items-center justify-center">
                            <i class="fas fa-user-shield text-blue-400 text-xs"></i>
                        </div>
                        <span>@(Context.Session.GetString("AdminName") ?? "Admin")</span>
                    </div>
                    <form method="post" action="/Auth/Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="flex items-center space-x-2 px-3 py-2 rounded-lg text-slate-300 hover:text-red-400 hover:bg-red-400/10 transition-all text-sm">
                            <i class="fas fa-sign-out-alt"></i>
                            <span class="hidden md:inline font-medium">Logout</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <!-- Page Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        <!-- Page heading -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Subscription Requests</h1>
                <p class="text-sm text-gray-500 mt-1">Review and action all incoming subscription requests</p>
            </div>
            <div class="flex items-center gap-3">
                <span class="inline-flex items-center gap-1.5 bg-amber-100 text-amber-700 text-sm font-semibold px-3 py-1.5 rounded-full">
                    <i class="fas fa-clock text-xs"></i>
                    @Model.Count(s => s.Status == "Pending") pending
                </span>
            </div>
        </div>

        <!-- Filter tabs -->
        <div class="flex gap-2 mb-6 flex-wrap">
            @foreach (var tab in new[] { ("all", "All"), ("Pending", "Pending"), ("Approved", "Approved"), ("Rejected", "Rejected") })
            {
                var active = filter.Equals(tab.Item1, StringComparison.OrdinalIgnoreCase);
                var count = tab.Item1 == "all"
                ? Model.Count
                : Model.Count(s => s.Status == tab.Item1);
                <a href="?filter=@tab.Item1"
                   class="px-4 py-2 rounded-lg text-sm font-semibold transition-all @(active ? "bg-gray-900 text-white shadow-sm" : "bg-white text-gray-600 border border-gray-200 hover:bg-gray-50")">
                    @tab.Item2
                    <span class="ml-1.5 text-xs @(active ? "bg-white/20" : "bg-gray-100") px-1.5 py-0.5 rounded-full">@count</span>
                </a>
            }
        </div>

        <!-- Table / Empty state -->
        @if (!Model.Any())
        {
            <div class="bg-white rounded-2xl border border-gray-100 p-16 text-center">
                <i class="fas fa-inbox text-4xl text-gray-200 mb-4"></i>
                <p class="text-gray-400 font-medium">No subscription requests found.</p>
            </div>
        }
        else
        {
            <!-- Desktop table -->
            <div class="hidden md:block bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100">
                            <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Tenant</th>
                            <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Plan</th>
                            <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Payment</th>
                            <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Amount</th>
                            <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Proof</th>
                            <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Submitted</th>
                            <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
                            <th class="px-5 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var s in Model)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors" id="row-@s.Id">
                                <td class="px-5 py-4">
                                    <p class="font-semibold text-gray-900">@s.TenantName</p>
                                    <p class="text-xs text-gray-400">@s.TenantEmail</p>
                                </td>
                                <td class="px-5 py-4"><span class="font-semibold text-gray-800">@s.SubscriptionPlan</span></td>
                                <td class="px-5 py-4">
                                    <p class="font-medium text-gray-700">@(s.PaymentMethod == "VodafoneCash" ? "Vodafone Cash" : s.PaymentMethod)</p>
                                    <p class="text-xs text-gray-400">@s.PhoneNumber</p>
                                    @if (!string.IsNullOrEmpty(s.TransactionReference))
                                    {
                                        <p class="text-xs text-blue-500 font-mono">@s.TransactionReference</p>
                                    }
                                </td>
                                <td class="px-5 py-4"><span class="font-bold text-gray-900">@s.Amount.ToString("N0") EGP</span></td>
                                <td class="px-5 py-4">
                                    <button onclick="openLightbox('@Html.Raw(s.PaymentProofUrl)')"
                                            class="w-14 h-14 rounded-lg overflow-hidden border-2 border-gray-200 hover:border-blue-400 transition-all focus:outline-none focus:ring-2 focus:ring-blue-500">
                                        <img src="@s.PaymentProofUrl" alt="Proof" class="w-full h-full object-cover" />
                                    </button>
                                </td>
                                <td class="px-5 py-4 text-gray-500 text-xs">
                                    <p>@s.SubmittedDate.ToString("MMM dd, yyyy")</p>
                                    <p>@s.SubmittedDate.ToString("hh:mm tt")</p>
                                </td>
                                <td class="px-5 py-4">
                                    <span class="status-badge-@s.Status.ToLower() text-xs font-bold px-3 py-1.5 rounded-full">@s.Status</span>
                                    @if (s.Status == "Rejected" && !string.IsNullOrEmpty(s.AdminNotes))
                                    {
                                        <p class="text-xs text-red-500 mt-1 max-w-[160px] truncate" title="@s.AdminNotes">@s.AdminNotes</p>
                                    }
                                    @if (s.ReviewedDate.HasValue)
                                    {
                                        <p class="text-xs text-gray-400 mt-0.5">by @s.ReviewedBy</p>
                                    }
                                </td>
                                <td class="px-5 py-4">
                                    @if (s.Status == "Pending")
                                    {
                                        <div class="flex gap-2">
                                            <button onclick="approveSubscription(@s.Id)"
                                                    class="px-3 py-1.5 bg-green-600 text-white text-xs font-semibold rounded-lg hover:bg-green-700 transition-all flex items-center gap-1">
                                                <i class="fas fa-check"></i> Approve
                                            </button>
                                            <button onclick="openRejectModal(@s.Id)"
                                                    class="px-3 py-1.5 bg-red-600 text-white text-xs font-semibold rounded-lg hover:bg-red-700 transition-all flex items-center gap-1">
                                                <i class="fas fa-times"></i> Reject
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-gray-400 italic">No action needed</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile cards -->
            <div class="md:hidden space-y-4">
                @foreach (var s in Model)
                {
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5" id="card-@s.Id">
                        <div class="flex items-start justify-between mb-3">
                            <div>
                                <p class="font-bold text-gray-900">@s.TenantName</p>
                                <p class="text-xs text-gray-400">@s.TenantEmail</p>
                            </div>
                            <span class="status-badge-@s.Status.ToLower() text-xs font-bold px-3 py-1.5 rounded-full">@s.Status</span>
                        </div>
                        <div class="grid grid-cols-2 gap-3 text-sm mb-4">
                            <div><p class="text-xs text-gray-400">Plan</p><p class="font-semibold">@s.SubscriptionPlan</p></div>
                            <div><p class="text-xs text-gray-400">Amount</p><p class="font-semibold">@s.Amount.ToString("N0") EGP</p></div>
                            <div><p class="text-xs text-gray-400">Payment</p><p class="font-semibold">@s.PaymentMethod</p></div>
                            <div><p class="text-xs text-gray-400">Date</p><p class="font-semibold">@s.SubmittedDate.ToString("MMM dd")</p></div>
                        </div>
                        <div class="flex items-center gap-3 mb-4">
                            <button onclick="openLightbox('@Html.Raw(s.PaymentProofUrl)')"
                                    class="flex items-center gap-2 text-sm text-blue-600 hover:text-blue-700">
                                <img src="@s.PaymentProofUrl" alt="Proof" class="w-10 h-10 rounded-lg object-cover border border-gray-200" />
                                <span>View Proof</span>
                            </button>
                        </div>
                        @if (s.Status == "Rejected" && !string.IsNullOrEmpty(s.AdminNotes))
                        {
                            <div class="bg-red-50 rounded-lg p-3 mb-4">
                                <p class="text-xs text-red-700"><strong>Reason:</strong> @s.AdminNotes</p>
                            </div>
                        }
                        @if (s.Status == "Pending")
                        {
                            <div class="flex gap-2">
                                <button onclick="approveSubscription(@s.Id)"
                                        class="flex-1 py-2.5 bg-green-600 text-white text-sm font-semibold rounded-xl hover:bg-green-700">
                                    <i class="fas fa-check mr-1"></i>Approve
                                </button>
                                <button onclick="openRejectModal(@s.Id)"
                                        class="flex-1 py-2.5 bg-red-600 text-white text-sm font-semibold rounded-xl hover:bg-red-700">
                                    <i class="fas fa-times mr-1"></i>Reject
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </main>

    <!-- Reject Modal (unchanged) -->
    <div id="rejectModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
            <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
                <h3 class="font-bold text-gray-900 text-lg flex items-center gap-2">
                    <i class="fas fa-times-circle text-red-500"></i> Reject Subscription
                </h3>
                <button onclick="closeRejectModal()" class="w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-all">
                    <i class="fas fa-times text-gray-500 text-sm"></i>
                </button>
            </div>
            <div class="px-6 py-5">
                <p class="text-sm text-gray-600 mb-4">You must provide a reason. This will be shown to the user so they can fix the issue and resubmit.</p>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Rejection Reason <span class="text-red-500">*</span></label>
                <textarea id="rejectReason" rows="4"
                          placeholder="e.g. The uploaded image is blurry. Please send a clear screenshot of the transfer confirmation."
                          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-400 focus:border-red-400 resize-none"></textarea>
                <p class="text-xs text-red-500 mt-1 hidden" id="rejectReasonError">Please enter a reason before rejecting.</p>
            </div>
            <div class="px-6 py-4 border-t border-gray-100 flex gap-3">
                <button onclick="closeRejectModal()" class="flex-1 py-3 border-2 border-gray-200 text-gray-600 rounded-xl font-semibold text-sm hover:bg-gray-50 transition-all">Cancel</button>
                <button onclick="confirmReject()" class="flex-1 py-3 bg-red-600 text-white rounded-xl font-semibold text-sm hover:bg-red-700 transition-all">
                    <i class="fas fa-ban mr-1"></i> Confirm Rejection
                </button>
            </div>
        </div>
    </div>

    <!-- Proof Lightbox (unchanged) -->
    <div id="lightboxOverlay" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4"
         onclick="closeLightbox()">
        <div class="relative max-w-xl w-full" onclick="event.stopPropagation()">
            <img id="lightboxImage" src="" alt="Payment proof" class="w-full rounded-2xl shadow-2xl max-h-[80vh] object-contain" />
            <button onclick="closeLightbox()" class="absolute -top-4 -right-4 w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center text-gray-700 hover:bg-gray-100 transition-all">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>

    <!-- Toast container -->
    <div id="toast-container" class="fixed top-4 right-4 z-50 flex flex-col gap-2"></div>

    <script src="@Url.Content("~/js/admin.js")"></script>
    <script>
        let _rejectId = null;

        function approveSubscription(id) {
            if (!confirm('Approve this subscription request?')) return;
            fetch(`/Admin/ApproveSubscription?id=${id}`, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        updateRowStatus(id, 'Approved');
                        showToast('Subscription approved!', 'success');
                    } else {
                        showToast(data.message || 'Failed to approve.', 'error');
                    }
                })
                .catch(() => showToast('Network error.', 'error'));
        }

        function openRejectModal(id) {
            _rejectId = id;
            document.getElementById('rejectReason').value = '';
            document.getElementById('rejectReasonError').classList.add('hidden');
            document.getElementById('rejectModal').classList.remove('hidden');
        }

        function closeRejectModal() {
            document.getElementById('rejectModal').classList.add('hidden');
            _rejectId = null;
        }

        function confirmReject() {
            const reason = document.getElementById('rejectReason').value.trim();
            if (!reason) { document.getElementById('rejectReasonError').classList.remove('hidden'); return; }
            document.getElementById('rejectReasonError').classList.add('hidden');
            fetch(`/Admin/RejectSubscription?id=${_rejectId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason })
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        updateRowStatus(_rejectId, 'Rejected', reason);
                        showToast('Subscription rejected.', 'warning');
                        closeRejectModal();
                    } else {
                        showToast(data.message || 'Failed to reject.', 'error');
                    }
                })
                .catch(() => showToast('Network error.', 'error'));
        }

        function updateRowStatus(id, status, reason) {
            const row = document.getElementById(`row-${id}`);
            if (row) {
                const cells = row.querySelectorAll('td');
                const badgeEl = cells[6]?.querySelector('span');
                if (badgeEl) { badgeEl.className = `status-badge-${status.toLowerCase()} text-xs font-bold px-3 py-1.5 rounded-full`; badgeEl.textContent = status; }
                const actionsCell = cells[7];
                if (actionsCell) actionsCell.innerHTML = '<span class="text-xs text-gray-400 italic">No action needed</span>';
            }
            const card = document.getElementById(`card-${id}`);
            if (card) {
                const badgeEl = card.querySelector('.rounded-full');
                if (badgeEl) { badgeEl.className = `status-badge-${status.toLowerCase()} text-xs font-bold px-3 py-1.5 rounded-full`; badgeEl.textContent = status; }
                const btns = card.querySelector('.flex.gap-2:last-child');
                if (btns) btns.remove();
            }
        }

        function openLightbox(url) {
            document.getElementById('lightboxImage').src = url;
            document.getElementById('lightboxOverlay').classList.remove('hidden');
        }
        function closeLightbox() { document.getElementById('lightboxOverlay').classList.add('hidden'); }
        document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeLightbox(); closeRejectModal(); } });
    </script>
</body>
</html>