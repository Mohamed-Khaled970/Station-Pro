@* =============================================================================
   FILE: Station_Pro/Views/Auth/ForgotPassword.cshtml
   ============================================================================= *@

@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Localization
@using StationPro
@inject IStringLocalizer<SharedResources> Localizer

@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;

    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.Culture.Name ?? "en-US";
    var isRtl = currentCulture.StartsWith("ar");

    var hasError = TempData["Error"] != null;
    var hasSuccess = TempData["Success"] != null;
    var errorMsg = TempData["Error"]?.ToString();
    var successMsg = TempData["Success"]?.ToString();
}

<!DOCTYPE html>
<html lang="@currentCulture" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='90'>🎮</text></svg>">
    <title>@ViewData["Title"] - StationPro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/auth.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        @@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap');

        body {
            font-family: @(isRtl ? "'Cairo', sans-serif" : "'Inter', sans-serif");
        }
    </style>
</head>
<body class="gaming-bg min-h-screen flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md slide-up">
        <div class="glass-card rounded-3xl shadow-2xl p-10">

            <!-- Icon & Title -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-20 h-20 icon-box rounded-3xl mb-5">
                    @if (hasError)
                    {
                        <i class="fas fa-exclamation-triangle text-white text-3xl"></i>
                    }
                    else if (hasSuccess)
                    {
                        <i class="fas fa-paper-plane text-white text-3xl"></i>
                    }
                    else
                    {
                        <i class="fas fa-key text-white text-3xl"></i>
                    }
                </div>

                @if (hasError)
                {
                    <h2 class="text-3xl font-bold text-gray-900 mb-2">Link Expired</h2>
                    <p class="text-gray-500 text-sm leading-relaxed">
                        This reset link is no longer valid.
                    </p>
                }
                else if (hasSuccess)
                {
                    <h2 class="text-3xl font-bold text-gray-900 mb-2">Check Your Email</h2>
                    <p class="text-gray-500 text-sm leading-relaxed">
                        We've sent a reset link to your inbox.
                    </p>
                }
                else
                {
                    <h2 class="text-3xl font-bold text-gray-900 mb-2">Forgot Password?</h2>
                    <p class="text-gray-500 text-sm leading-relaxed">
                        No worries! Enter your email and we'll send you a reset link.
                    </p>
                }
            </div>

            @* ── ERROR state: message + "Request New Link" button, NO form ── *@
            @if (hasError)
            {
                <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-exclamation-circle text-red-500 mt-0.5 flex-shrink-0"></i>
                        <p class="text-sm text-red-700">@errorMsg</p>
                    </div>
                </div>

                @* Link to GET ForgotPassword — loads a clean fresh page with the form *@
                <a href="@Url.Action("ForgotPassword", "Auth")"
                   class="btn-primary w-full py-4 rounded-xl text-white font-semibold
                          text-base shadow-lg text-center block">
                    <i class="fas fa-redo @(isRtl ? "ml-2" : "mr-2")"></i>
                    Request a New Link
                </a>
            }

            @* ── SUCCESS state: message only, NO form ── *@
            else if (hasSuccess)
            {
                <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-check-circle text-green-500 mt-0.5 flex-shrink-0"></i>
                        <p class="text-sm text-green-700">@successMsg</p>
                    </div>
                </div>

                <p class="text-center text-gray-500 text-sm mb-4">
                    Didn't receive it?
                    <a href="@Url.Action("ForgotPassword", "Auth")"
                       class="text-indigo-600 hover:text-indigo-700 font-semibold">
                        Try again
                    </a>
                </p>
            }

            @* ── DEFAULT state: show the form ── *@
            else
            {
                <form asp-action="ForgotPassword" asp-controller="Auth" method="POST" class="space-y-5">
                    @Html.AntiForgeryToken()

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            <i class="fas fa-envelope text-indigo-600 @(isRtl ? "ml-2" : "mr-2")"></i>Email Address
                        </label>
                        <input type="email"
                               name="email"
                               class="form-input w-full px-4 py-3.5 border border-gray-300 rounded-xl
                                      focus:ring-2 focus:ring-indigo-500 focus:border-transparent
                                      outline-none text-gray-900"
                               placeholder="your@email.com"
                               autocomplete="email"
                               dir="ltr"
                               required>
                    </div>

                    <button type="submit" id="forgot-submit"
                            class="btn-primary w-full py-4 rounded-xl text-white font-semibold
                                   text-base shadow-lg">
                        <i class="fas fa-paper-plane @(isRtl ? "ml-2" : "mr-2")"></i>
                        Send Reset Link
                    </button>
                </form>
            }

            <!-- Back to login — always visible -->
            <div class="mt-6 text-center">
                <a href="@Url.Action("Login", "Auth")"
                   class="text-sm text-indigo-600 hover:text-indigo-700 font-semibold">
                    <i class="fas fa-arrow-left @(isRtl ? "ml-2" : "mr-2") text-xs"></i>
                    Back to Login
                </a>
            </div>

        </div>
    </div>

    <script>
        document.querySelector('form')?.addEventListener('submit', function () {
            const btn = document.getElementById('forgot-submit');
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Sending...';
            }
        });
    </script>
</body>
</html>
