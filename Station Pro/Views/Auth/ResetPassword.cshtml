@* =============================================================================
   FILE: Station_Pro/Views/Auth/ResetPassword.cshtml
   ============================================================================= *@

@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Localization
@using StationPro
@inject IStringLocalizer<SharedResources> Localizer

@model string  

@{
    ViewData["Title"] = "Reset Password";
    Layout = null;

    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.Culture.Name ?? "en-US";
    var isRtl = currentCulture.StartsWith("ar");
}

<!DOCTYPE html>
<html lang="@currentCulture" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='90'>🎮</text></svg>">
    <title>@ViewData["Title"] - StationPro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/auth.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        @@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap');
        body { font-family: @(isRtl ? "'Cairo', sans-serif" : "'Inter', sans-serif"); }
    </style>
</head>
<body class="gaming-bg min-h-screen flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md slide-up">
        <div class="glass-card rounded-3xl shadow-2xl p-10">

            <!-- Icon & Title -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-20 h-20 icon-box rounded-3xl mb-5">
                    <i class="fas fa-lock text-white text-3xl"></i>
                </div>
                <h2 class="text-3xl font-bold text-gray-900 mb-2">Set New Password</h2>
                <p class="text-gray-500 text-sm leading-relaxed">
                    Choose a strong password for your StationPro account.
                </p>
            </div>

            @* ── Error message ── *@
            @if (TempData["Error"] != null)
            {
                <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-exclamation-circle text-red-500 mt-0.5 flex-shrink-0"></i>
                        <p class="text-sm text-red-700">@TempData["Error"]</p>
                    </div>
                </div>
            }

            <form asp-action="ResetPassword" asp-controller="Auth" method="POST" class="space-y-5">
                @Html.AntiForgeryToken()

                @* Hidden token *@
                <input type="hidden" name="token" value="@Model" />

                <!-- New Password -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        <i class="fas fa-lock text-indigo-600 @(isRtl ? "ml-2" : "mr-2")"></i>New Password
                    </label>
                    <div class="relative">
                        <input type="password"
                               name="newPassword"
                               id="new-password"
                               class="form-input w-full px-4 py-3.5 @(isRtl ? "pl-12" : "pr-12")
                                      border border-gray-300 rounded-xl
                                      focus:ring-2 focus:ring-indigo-500 focus:border-transparent
                                      outline-none text-gray-900"
                               placeholder="Min. 6 characters"
                               minlength="6"
                               dir="ltr"
                               required>
                        <button type="button" onclick="togglePassword('new-password')"
                                class="absolute @(isRtl ? "left-4" : "right-4") top-1/2 -translate-y-1/2
                                       text-gray-400 hover:text-gray-600">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>

                <!-- Confirm New Password -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        <i class="fas fa-lock text-indigo-600 @(isRtl ? "ml-2" : "mr-2")"></i>Confirm New Password
                    </label>
                    <div class="relative">
                        <input type="password"
                               name="confirmPassword"
                               id="confirm-new-password"
                               class="form-input w-full px-4 py-3.5 @(isRtl ? "pl-12" : "pr-12")
                                      border border-gray-300 rounded-xl
                                      focus:ring-2 focus:ring-indigo-500 focus:border-transparent
                                      outline-none text-gray-900"
                               placeholder="Repeat your new password"
                               dir="ltr"
                               required>
                        <button type="button" onclick="togglePassword('confirm-new-password')"
                                class="absolute @(isRtl ? "left-4" : "right-4") top-1/2 -translate-y-1/2
                                       text-gray-400 hover:text-gray-600">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <p class="hidden text-red-500 text-xs mt-1" id="reset-match-error">
                        Passwords do not match.
                    </p>
                </div>

                <!-- Submit -->
                <button type="submit" id="reset-submit"
                        class="btn-primary w-full py-4 rounded-xl text-white font-semibold text-base shadow-lg">
                    <i class="fas fa-check @(isRtl ? "ml-2" : "mr-2")"></i>
                    Reset Password
                </button>
            </form>

            <!-- Back to login -->
            <div class="mt-6 text-center">
                <a href="@Url.Action("Login", "Auth")"
                   class="text-sm text-indigo-600 hover:text-indigo-700 font-semibold">
                    <i class="fas fa-arrow-left @(isRtl ? "ml-2" : "mr-2") text-xs"></i>
                    Back to Login
                </a>
            </div>

        </div>
    </div>

    <script>
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = input?.nextElementSibling?.querySelector('i');
            if (!input || !icon) return;
            const hidden = input.type === 'password';
            input.type = hidden ? 'text' : 'password';
            icon.classList.toggle('fa-eye', !hidden);
            icon.classList.toggle('fa-eye-slash', hidden);
        }

        // Live match check
        const newPwd   = document.getElementById('new-password');
        const confirmP = document.getElementById('confirm-new-password');
        const matchErr = document.getElementById('reset-match-error');

        confirmP?.addEventListener('input', () => {
            const mismatch = confirmP.value && newPwd.value !== confirmP.value;
            matchErr?.classList.toggle('hidden', !mismatch);
        });

        // Submit validation
        document.querySelector('form')?.addEventListener('submit', function (e) {
            if (newPwd.value !== confirmP.value) {
                e.preventDefault();
                matchErr?.classList.remove('hidden');
                return;
            }
            const btn = document.getElementById('reset-submit');
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Resetting...';
            }
        });
    </script>
</body>
</html>
