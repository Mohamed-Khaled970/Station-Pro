@* =============================================================================
   FILE: Views/Subscription/Rejected.cshtml
   ============================================================================= *@

@model StationPro.Application.DTOs.Subscriptions.SubscriptionStatusViewModel
@{
    ViewData["Title"] = "Subscription Rejected";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='90'>🎮</text></svg>">
    <title>@ViewData["Title"] – Station Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/subscribe.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-red-50 via-white to-orange-50">

    <!-- Header -->
    <header class="bg-white/80 backdrop-blur border-b border-gray-100 py-4 px-6 flex items-center justify-between">
        <div class="flex items-center gap-2">
            <i class="fas fa-gamepad text-blue-600 text-2xl"></i>
            <span class="text-xl font-bold text-gray-900">Station Pro</span>
        </div>
        <span class="text-sm text-gray-400">Subscription Review</span>
    </header>

    <main class="flex items-center justify-center min-h-[calc(100vh-64px)] px-4 py-12">
        <div class="w-full max-w-lg">

            <!-- Icon -->
            <div class="flex justify-center mb-8">
                <div class="w-24 h-24 rounded-full bg-red-100 flex items-center justify-center">
                    <i class="fas fa-times-circle text-red-500 text-4xl"></i>
                </div>
            </div>

            <!-- Status card -->
            <div class="bg-white rounded-3xl shadow-xl border border-red-100 overflow-hidden mb-6">
                <div class="bg-gradient-to-r from-red-500 to-orange-500 px-8 py-6 text-center card-header-pad">
                    <h1 class="text-2xl font-extrabold text-white mb-1">Subscription Rejected</h1>
                    <p class="text-red-50 text-sm">Please review the reason below and resubmit.</p>
                </div>

                <div class="px-8 py-7 mobile-pad">
                    <div class="flex items-center justify-between mb-5">
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Status</span>
                        <span class="inline-flex items-center gap-1.5 bg-red-100 text-red-700 font-semibold text-sm px-4 py-1.5 rounded-full">
                            <i class="fas fa-ban text-xs"></i> Rejected
                        </span>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-5 info-row">
                        <div class="bg-gray-50 rounded-xl p-4">
                            <p class="text-xs text-gray-400 uppercase mb-1">Plan</p>
                            <p class="font-bold text-gray-900">@Model.PlanName</p>
                        </div>
                        <div class="bg-gray-50 rounded-xl p-4">
                            <p class="text-xs text-gray-400 uppercase mb-1">Submitted</p>
                            <p class="font-bold text-gray-900">@Model.SubmittedDate.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>

                    <div class="bg-red-50 border border-red-200 rounded-xl p-5">
                        <p class="text-sm font-semibold text-red-800 flex items-center gap-2 mb-2">
                            <i class="fas fa-exclamation-circle"></i> Reason for Rejection
                        </p>
                        <p class="text-red-700 text-sm">
                            @(string.IsNullOrWhiteSpace(Model.RejectionReason)
                                ? "No specific reason was provided. Please contact support."
                                : Model.RejectionReason)
                        </p>
                    </div>
                </div>
            </div>

            <!-- Server-side error banner -->
            @if (TempData["Error"] != null)
            {
                var parts = TempData["Error"]!.ToString()!.Split('|');
                <div class="flex items-start gap-3 bg-red-50 border border-red-300 rounded-2xl p-4 mb-4">
                    <i class="fas fa-exclamation-circle text-red-500 mt-0.5 flex-shrink-0"></i>
                    <div>
                        <p class="text-sm font-bold text-red-800">@parts[0]</p>
                        @if (parts.Length > 1)
                        {
                            <p class="text-sm text-red-700 mt-0.5">@parts[1]</p>
                        }
                    </div>
                </div>
            }

            <!-- Re-upload form card -->
            <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
                <div class="bg-gray-900 px-8 py-5 card-header-pad">
                    <h2 class="text-lg font-bold text-white flex items-center gap-2">
                        <i class="fas fa-redo text-blue-400"></i> Submit a New Request
                    </h2>
                    <p class="text-gray-400 text-sm mt-0.5">Upload a new payment screenshot to try again.</p>
                </div>

                <form id="resubmitForm"
                      asp-action="Resubmit" asp-controller="Subscription"
                      method="post" enctype="multipart/form-data"
                      novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="TenantId" value="@Model.TenantId" />

                    <div class="px-8 py-7 space-y-5 mobile-pad">

                        <!-- Payment method -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                Payment Method <span class="text-red-500">*</span>
                            </label>
                            <select id="resubmit-method" name="PaymentMethod"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 text-sm">
                                <option value="">— Select —</option>
                                @if (Model.PaymentMethod == "VodafoneCash")
                                {
                                    <option value="VodafoneCash" selected>Vodafone Cash</option>
                                    <option value="InstaPay">InstaPay</option>
                                }
                                else if (Model.PaymentMethod == "InstaPay")
                                {
                                    <option value="VodafoneCash">Vodafone Cash</option>
                                    <option value="InstaPay" selected>InstaPay</option>
                                }
                                else
                                {
                                    <option value="VodafoneCash">Vodafone Cash</option>
                                    <option value="InstaPay">InstaPay</option>
                                }
                            </select>
                            <p class="field-error" id="err-method">Please select a payment method.</p>
                        </div>

                        <!-- Phone & transaction ref -->
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                    Phone Number <span class="text-red-500">*</span>
                                </label>
                                <input type="tel" id="resubmit-phone" name="PhoneNumber"
                                       placeholder="01XXXXXXXXX" maxlength="11"
                                       class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 text-sm" />
                                <p class="field-error" id="err-phone">Enter a valid 10–11 digit number.</p>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                    Transaction Ref <span class="text-gray-400">(opt.)</span>
                                </label>
                                <input type="text" name="TransactionReference"
                                       placeholder="e.g. VF123"
                                       class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 text-sm" />
                            </div>
                        </div>

                        <!-- Notes -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                Notes <span class="text-gray-400">(opt.)</span>
                            </label>
                            <textarea name="Notes" rows="2"
                                      class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 text-sm resize-none"
                                      placeholder="Anything the admin should know…"></textarea>
                        </div>

                        <!-- File upload — same enhanced zone as subscribe page -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                New Payment Screenshot <span class="text-red-500">*</span>
                            </label>

                            <div id="reuploadZone"
                                 class="border-2 border-dashed border-gray-300 rounded-xl text-center cursor-pointer hover:border-blue-400 hover:bg-blue-50/30 transition-all drop-zone-inner"
                                 style="padding: 2.5rem 1rem;"
                                 onclick="document.getElementById('reuploadInput').click()"
                                 ondragover="event.preventDefault(); this.classList.add('border-blue-500','bg-blue-50')"
                                 ondragleave="this.classList.remove('border-blue-500','bg-blue-50')"
                                 ondrop="handleReuploadDrop(event)">
                                <i class="fas fa-cloud-upload-alt upload-icon text-4xl text-gray-300 mb-3 block"></i>
                                <p class="text-gray-600 font-medium mb-1 text-sm">Click to upload or drag and drop</p>
                                <p class="text-xs text-gray-400">PNG, JPG up to 5 MB — auto compressed</p>
                                <input type="file" name="PaymentProof" id="reuploadInput"
                                       accept="image/png,image/jpeg,image/jpg" class="hidden"
                                       onchange="previewReupload(this)" />
                            </div>

                            <div class="upload-error" id="err-file">
                                <i class="fas fa-exclamation-circle flex-shrink-0"></i>
                                <span>Please upload a payment screenshot (PNG or JPG).</span>
                            </div>

                            <!-- Preview -->
                            <div id="reuploadPreview" class="mt-3 hidden">
                                <div class="relative inline-block max-w-full">
                                    <img id="reuploadImg" src="" alt="Preview"
                                         class="max-h-48 rounded-xl border border-gray-200 shadow-sm" />
                                    <button type="button" onclick="removeReupload()"
                                            class="absolute top-2 right-2 w-7 h-7 bg-red-500 text-white rounded-full flex items-center justify-center text-xs hover:bg-red-600 transition-all">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <button type="submit" id="resubmitBtn"
                                class="w-full py-3.5 bg-blue-600 text-white rounded-xl font-bold hover:bg-blue-700 transition-all flex items-center justify-center gap-2">
                            <i class="fas fa-paper-plane"></i> Resubmit for Review
                        </button>
                    </div>
                </form>
            </div>

            <p class="text-center mt-6 text-sm text-gray-400">
                Need help?
                <a href="mailto:support@@stationpro.app" class="text-blue-600 hover:underline ml-1">Contact support</a>
            </p>
        </div>
    </main>

    <script src="~/js/subscribe.js"></script>
</body>
</html>
