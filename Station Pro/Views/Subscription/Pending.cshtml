@* =============================================================================
   FILE: Views/Subscription/Pending.cshtml
   ============================================================================= *@

@model StationPro.Application.DTOs.Subscriptions.SubscriptionStatusViewModel
@{
    ViewData["Title"] = "Subscription Under Review";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='90'>🎮</text></svg>">
    <title>@ViewData["Title"] – Station Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .pulse-ring {
            animation: pulse-ring 2.4s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
        }

        @@keyframes pulse-ring {
            0% {
                transform: scale(0.85);
                box-shadow: 0 0 0 0 rgba(234,179,8,0.5);
            }

            70% {
                transform: scale(1);
                box-shadow: 0 0 0 20px rgba(234,179,8,0);
            }

            100% {
                transform: scale(0.85);
                box-shadow: 0 0 0 0 rgba(234,179,8,0);
            }
        }

        .dot-bounce span {
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #ca8a04;
            margin: 0 2px;
            animation: bounce 1.4s infinite ease-in-out;
        }

            .dot-bounce span:nth-child(1) {
                animation-delay: -0.32s;
            }

            .dot-bounce span:nth-child(2) {
                animation-delay: -0.16s;
            }

        @@keyframes bounce {
            0%, 80%, 100% {
                transform: scale(0);
            }

            40% {
                transform: scale(1);
            }
        }

        .info-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }

        @@media (max-width: 480px) {
            .info-row {
                grid-template-columns: 1fr 1fr;
                gap: 0.5rem;
            }

                .info-row > div {
                    padding: 0.625rem !important;
                }

                .info-row .info-label {
                    font-size: 0.65rem;
                }

                .info-row .info-value {
                    font-size: 0.8rem;
                }

                .info-row .info-sub {
                    font-size: 0.65rem;
                }
        }
    </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-amber-50 via-white to-yellow-50">

    <!-- Header -->
    <header class="bg-white/80 backdrop-blur border-b border-gray-100 py-3 sm:py-4 px-4 sm:px-6 flex items-center justify-between">
        <div class="flex items-center gap-2">
            <i class="fas fa-gamepad text-blue-600 text-xl sm:text-2xl"></i>
            <span class="text-base sm:text-xl font-bold text-gray-900">Station Pro</span>
        </div>
        <span class="text-xs sm:text-sm text-gray-400">Subscription Review</span>
    </header>

    <main class="flex items-center justify-center min-h-[calc(100vh-56px)] px-3 sm:px-4 py-6 sm:py-12">
        <div class="w-full max-w-lg">

            <!-- Animated icon -->
            <div class="flex justify-center mb-5 sm:mb-8">
                <div class="w-16 h-16 sm:w-24 sm:h-24 rounded-full bg-amber-100 flex items-center justify-center pulse-ring">
                    <i class="fas fa-clock text-amber-500 text-2xl sm:text-4xl"></i>
                </div>
            </div>

            <!-- Main card -->
            <div class="bg-white rounded-2xl sm:rounded-3xl shadow-xl border border-amber-100 overflow-hidden">

                <!-- Card header -->
                <div class="bg-gradient-to-r from-amber-400 to-yellow-400 px-5 sm:px-8 py-4 sm:py-6 text-center">
                    <h1 class="text-lg sm:text-2xl font-extrabold text-white mb-0.5 sm:mb-1">
                        Your request is under review
                    </h1>
                    <p class="text-amber-50 text-xs sm:text-sm">We'll activate your account within 24 hours</p>
                </div>

                <!-- Card body -->
                <div class="px-4 sm:px-8 py-5 sm:py-7">

                    <!-- Just-submitted success message -->
                    @if (TempData["SubscriptionSubmitted"]?.ToString() == "true" ||
                    TempData["ResubmitSuccess"]?.ToString() == "true")
                    {
                        <div class="flex items-start gap-2 sm:gap-3 bg-green-50 border border-green-200 rounded-xl p-3 sm:p-4 mb-4 sm:mb-6">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 flex-shrink-0 text-sm sm:text-base"></i>
                            <p class="text-xs sm:text-sm text-green-800 font-medium">
                                Your payment proof has been submitted successfully! Our admin team will review it shortly.
                            </p>
                        </div>
                    }

                    <!-- Status badge -->
                    <div class="flex items-center justify-between mb-4 sm:mb-5">
                        <span class="text-xs sm:text-sm font-semibold text-gray-500 uppercase tracking-wide">Current Status</span>
                        <span class="inline-flex items-center gap-1 sm:gap-1.5 bg-amber-100 text-amber-700 font-semibold text-xs sm:text-sm px-3 sm:px-4 py-1 sm:py-1.5 rounded-full">
                            <span class="dot-bounce"><span></span><span></span><span></span></span>
                            Pending
                        </span>
                    </div>

                    <!-- Request details -->
                    <div class="info-row mb-4 sm:mb-6">
                        <div class="bg-gray-50 rounded-xl p-3 sm:p-4">
                            <p class="info-label text-xs text-gray-400 uppercase tracking-wide mb-0.5 sm:mb-1">Plan</p>
                            <p class="info-value font-bold text-gray-900 text-base sm:text-lg">@Model.PlanName</p>
                        </div>
                        <div class="bg-gray-50 rounded-xl p-3 sm:p-4">
                            <p class="info-label text-xs text-gray-400 uppercase tracking-wide mb-0.5 sm:mb-1">Payment</p>
                            <p class="info-value font-bold text-gray-900 text-sm sm:text-base">
                                @(Model.PaymentMethod == "VodafoneCash" ? "Vodafone Cash" : Model.PaymentMethod)
                            </p>
                        </div>
                        <div class="bg-gray-50 rounded-xl p-3 sm:p-4">
                            <p class="info-label text-xs text-gray-400 uppercase tracking-wide mb-0.5 sm:mb-1">Submitted</p>
                            <p class="info-value font-bold text-gray-900 text-sm sm:text-base">@Model.SubmittedDate.ToString("MMM dd, yyyy")</p>
                            <p class="info-sub text-xs text-gray-400">@Model.SubmittedDate.ToString("hh:mm tt")</p>
                        </div>
                        <div class="bg-gray-50 rounded-xl p-3 sm:p-4">
                            <p class="info-label text-xs text-gray-400 uppercase tracking-wide mb-0.5 sm:mb-1">Activation</p>
                            <p class="info-value font-bold text-gray-900 text-sm sm:text-base">Within 24h</p>
                        </div>
                    </div>

                    <!-- What happens next -->
                    <div class="bg-blue-50 border border-blue-100 rounded-xl p-3 sm:p-5 mb-4 sm:mb-6">
                        <p class="text-xs sm:text-sm font-semibold text-blue-800 mb-2 sm:mb-3 flex items-center gap-2">
                            <i class="fas fa-info-circle flex-shrink-0"></i> What happens next?
                        </p>
                        <ol class="text-xs sm:text-sm text-blue-700 space-y-1 sm:space-y-2">
                            <li class="flex gap-2"><span class="font-bold flex-shrink-0">1.</span> Our admin team reviews your payment proof.</li>
                            <li class="flex gap-2"><span class="font-bold flex-shrink-0">2.</span> Your account gets activated (usually within a few hours).</li>
                            <li class="flex gap-2"><span class="font-bold flex-shrink-0">3.</span> This page will automatically redirect you to the dashboard once approved.</li>
                        </ol>
                    </div>

                    <!-- Auto-refresh hint -->
                    <p class="text-xs text-gray-400 text-center" id="pollStatus">
                        <i class="fas fa-sync-alt mr-1"></i>Checking for updates every 30 seconds…
                    </p>
                </div>
            </div>

            <!-- Sign out link — uses AuthController.Logout (POST) via a form -->
            <div class="text-center mt-5 sm:mt-6">
                <p class="text-xs sm:text-sm text-gray-400">
                    Wrong account?
                    <form method="post" asp-action="Logout" asp-controller="Auth" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="text-blue-600 hover:underline font-medium ml-1 text-xs sm:text-sm bg-transparent border-none cursor-pointer p-0">
                            Sign out
                        </button>
                    </form>
                </p>
            </div>
        </div>
    </main>

    <script>
        const tenantId = @Model.TenantId;

        async function checkStatus() {
            try {
                const r = await fetch(`/Subscription/CheckStatus?tenantId=${tenantId}`);
                const data = await r.json();

                if (data.status === 'Approved') {
                    document.getElementById('pollStatus').innerHTML =
                        '<i class="fas fa-check-circle text-green-500 mr-1"></i>' +
                        '<strong class="text-green-600">Approved!</strong> Redirecting to dashboard…';
                    setTimeout(() => window.location.href = '/Dashboard/Index', 1500);
                } else if (data.status === 'Rejected') {
                    window.location.href = `/Subscription/Rejected?tenantId=${tenantId}`;
                }
            } catch {
                // Network error — silently ignore, will retry next tick
            }
        }

        setInterval(checkStatus, 30_000);
    </script>
</body>
</html>
