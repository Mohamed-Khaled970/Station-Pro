@* =============================================================================
   FILE: Views/Subscription/Subscribe.cshtml
   ============================================================================= *@

@model StationPro.Application.DTOs.Subscriptions.SubscriptionViewModel
@{
    ViewData["Title"] = "Choose Your Plan";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='90'>🎮</text></svg>">
    <title>@ViewData["Title"] – Station Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/subscribe.css">
</head>
<body class="bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen">

    <!-- Header -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-3 sm:px-6 py-3 sm:py-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <i class="fas fa-gamepad text-blue-600 text-xl sm:text-2xl"></i>
                <span class="text-base sm:text-xl font-bold text-gray-900">Station Pro</span>
            </div>
            <a href="/" class="flex items-center gap-1.5 px-3 py-1.5 sm:px-4 sm:py-2 border-2 border-gray-300 text-gray-600 rounded-lg font-semibold text-xs sm:text-sm hover:border-blue-400 hover:text-blue-600 transition-all">
                <i class="fas fa-home"></i>
                <span class="hidden xs:inline sm:inline">Back to Home</span>
                <span class="inline sm:hidden xs:hidden">Home</span>
            </a>
        </div>
    </header>

    <div class="py-5 sm:py-8 px-3 sm:px-4">
        <div class="max-w-5xl mx-auto">

            <!-- Page title -->
            <div class="text-center mb-5 sm:mb-8">
                <h1 class="text-xl sm:text-3xl font-bold text-gray-900 mb-1 sm:mb-2">🎮 Choose Your Plan</h1>
                <p class="text-gray-600 text-sm sm:text-base">Welcome, <strong>@Model.TenantName</strong>! Select a plan to activate your store.</p>
            </div>

            <!-- Pending notice -->
            @if (Model.HasPendingSubscription)
            {
                <div class="bg-amber-50 border-l-4 border-amber-400 rounded-lg p-3 sm:p-4 mb-5 sm:mb-6 flex gap-3">
                    <i class="fas fa-clock text-amber-500 mt-0.5 flex-shrink-0"></i>
                    <div>
                        <p class="font-semibold text-amber-800 text-sm">Subscription Pending Review</p>
                        <p class="text-amber-700 text-xs sm:text-sm mt-1">
                            You already have a <strong>@Model.PendingSubscriptionPlan</strong> plan request waiting for admin approval.
                            Submitting again will replace it.
                        </p>
                    </div>
                </div>
            }

            <!-- TempData errors -->
            @if (TempData["Error"] != null)
            {
                var parts = TempData["Error"]!.ToString()!.Split('|');
                <div class="bg-red-50 border border-red-200 rounded-lg p-3 sm:p-4 mb-5 sm:mb-6 flex gap-3">
                    <i class="fas fa-exclamation-circle text-red-500 mt-0.5 flex-shrink-0"></i>
                    <div>
                        <p class="font-semibold text-red-800 text-sm">@parts[0]</p>
                        @if (parts.Length > 1)
                        {
                            <p class="text-red-700 text-xs sm:text-sm mt-1">@parts[1]</p>
                        }
                    </div>
                </div>
            }

            <!-- ── Step Indicators ─────────────────────────────────────── -->
            <div class="flex items-center justify-center mb-6 sm:mb-8 select-none" id="step-indicator-row">
                <!-- Step 1 -->
                <div class="flex items-center gap-1 sm:gap-2" id="ind-1">
                    <div class="w-7 h-7 sm:w-9 sm:h-9 rounded-full flex items-center justify-center font-bold text-xs sm:text-sm bg-blue-600 text-white flex-shrink-0" id="step1-circle">1</div>
                    <span class="font-semibold text-gray-900 text-xs sm:text-sm whitespace-nowrap" id="step1-label">Choose Plan</span>
                </div>

                <div class="w-6 sm:w-12 h-0.5 bg-gray-300 mx-1 sm:mx-2 flex-shrink-0" id="line-1-2"></div>

                <!-- Step 2 -->
                <div class="flex items-center gap-1 sm:gap-2" id="ind-2">
                    <div class="w-7 h-7 sm:w-9 sm:h-9 rounded-full flex items-center justify-center font-bold text-xs sm:text-sm bg-gray-200 text-gray-500 flex-shrink-0" id="step2-circle">2</div>
                    <span class="font-semibold text-gray-400 text-xs sm:text-sm whitespace-nowrap" id="step2-label">Payment</span>
                </div>

                <div class="w-6 sm:w-12 h-0.5 bg-gray-300 mx-1 sm:mx-2 flex-shrink-0" id="line-2-3"></div>

                <!-- Step 3 -->
                <div class="flex items-center gap-1 sm:gap-2" id="ind-3">
                    <div class="w-7 h-7 sm:w-9 sm:h-9 rounded-full flex items-center justify-center font-bold text-xs sm:text-sm bg-gray-200 text-gray-500 flex-shrink-0" id="step3-circle">3</div>
                    <span class="font-semibold text-gray-400 text-xs sm:text-sm whitespace-nowrap" id="step3-label">Upload</span>
                </div>
            </div>

            <!-- ════════════════════════════════════════════════════════════
                 STEP 1 — Plan Selection
                 ════════════════════════════════════════════════════════════ -->
            <div id="section-plans">
                <div class="grid grid-cols-1 sm:grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 mb-6">

                    <!-- Basic -->
                    <div class="plan-card bg-white rounded-2xl border-2 border-gray-200 p-4 sm:p-6 cursor-pointer hover:border-blue-400 hover:shadow-lg transition-all"
                         onclick="selectPlan('Basic', 29, this)">
                        <div class="flex sm:block items-center gap-4 sm:gap-0 sm:text-center mb-3 sm:mb-5">
                            <div class="w-11 h-11 sm:w-14 sm:h-14 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0 sm:mx-auto sm:mb-3">
                                <i class="fas fa-star text-blue-600 text-lg sm:text-2xl"></i>
                            </div>
                            <div class="sm:text-center">
                                <h3 class="text-base sm:text-xl font-bold text-gray-900">Basic</h3>
                                <p class="text-xs sm:text-sm text-gray-500">Perfect for small stores</p>
                            </div>
                            <!-- Mobile: price inline -->
                            <div class="ml-auto sm:hidden">
                                <span class="text-2xl font-extrabold text-gray-900">29</span>
                                <span class="text-gray-500 text-xs"> EGP/mo</span>
                            </div>
                        </div>
                        <!-- Desktop: price centered -->
                        <div class="hidden sm:block text-center mb-5">
                            <span class="text-4xl font-extrabold text-gray-900">29</span>
                            <span class="text-gray-500"> EGP/mo</span>
                        </div>
                        <ul class="space-y-1.5 sm:space-y-2 text-xs sm:text-sm">
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Up to 10 devices</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Basic reports</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Email support</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Session tracking</li>
                        </ul>
                    </div>

                    <!-- Pro (highlighted) -->
                    <div class="plan-card bg-white rounded-2xl border-2 border-purple-400 shadow-lg p-4 sm:p-6 cursor-pointer hover:shadow-xl transition-all relative"
                         onclick="selectPlan('Pro', 79, this)">
                        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                            <span class="bg-purple-600 text-white px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide">Most Popular</span>
                        </div>
                        <div class="flex sm:block items-center gap-4 sm:gap-0 sm:text-center mb-3 sm:mb-5 mt-1 sm:mt-0">
                            <div class="w-11 h-11 sm:w-14 sm:h-14 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0 sm:mx-auto sm:mb-3">
                                <i class="fas fa-gem text-purple-600 text-lg sm:text-2xl"></i>
                            </div>
                            <div class="sm:text-center">
                                <h3 class="text-base sm:text-xl font-bold text-gray-900">Pro</h3>
                                <p class="text-xs sm:text-sm text-gray-500">For growing businesses</p>
                            </div>
                            <div class="ml-auto sm:hidden">
                                <span class="text-2xl font-extrabold text-gray-900">79</span>
                                <span class="text-gray-500 text-xs"> EGP/mo</span>
                            </div>
                        </div>
                        <div class="hidden sm:block text-center mb-5">
                            <span class="text-4xl font-extrabold text-gray-900">79</span>
                            <span class="text-gray-500"> EGP/mo</span>
                        </div>
                        <ul class="space-y-1.5 sm:space-y-2 text-xs sm:text-sm">
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Up to 50 devices</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Advanced analytics</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Priority support</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Custom branding</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Revenue forecasting</li>
                        </ul>
                    </div>

                    <!-- Enterprise -->
                    <div class="plan-card bg-white rounded-2xl border-2 border-gray-200 p-4 sm:p-6 cursor-pointer hover:border-orange-400 hover:shadow-lg transition-all"
                         onclick="selectPlan('Enterprise', 199, this)">
                        <div class="flex sm:block items-center gap-4 sm:gap-0 sm:text-center mb-3 sm:mb-5">
                            <div class="w-11 h-11 sm:w-14 sm:h-14 bg-orange-100 rounded-full flex items-center justify-center flex-shrink-0 sm:mx-auto sm:mb-3">
                                <i class="fas fa-crown text-orange-500 text-lg sm:text-2xl"></i>
                            </div>
                            <div class="sm:text-center">
                                <h3 class="text-base sm:text-xl font-bold text-gray-900">Enterprise</h3>
                                <p class="text-xs sm:text-sm text-gray-500">For large operations</p>
                            </div>
                            <div class="ml-auto sm:hidden">
                                <span class="text-2xl font-extrabold text-gray-900">199</span>
                                <span class="text-gray-500 text-xs"> EGP/mo</span>
                            </div>
                        </div>
                        <div class="hidden sm:block text-center mb-5">
                            <span class="text-4xl font-extrabold text-gray-900">199</span>
                            <span class="text-gray-500"> EGP/mo</span>
                        </div>
                        <ul class="space-y-1.5 sm:space-y-2 text-xs sm:text-sm">
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Unlimited devices</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>All Pro features</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Dedicated support</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Custom integrations</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check text-green-500 text-xs"></i>Multi-location support</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- ════════════════════════════════════════════════════════════
                 STEP 2 — Payment Information
                 ════════════════════════════════════════════════════════════ -->
            <div id="section-payment" class="hidden">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 sm:p-8 mb-6">
                    <h2 class="text-lg sm:text-2xl font-bold text-gray-900 mb-4 sm:mb-6">
                        <i class="fas fa-credit-card text-blue-600 mr-2"></i>Payment Information
                    </h2>

                    <!-- Payment instruction banner -->
                    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 sm:p-5 mb-5 sm:mb-6">
                        <h3 class="font-semibold text-blue-900 flex items-center gap-2 mb-2 sm:mb-3 text-sm sm:text-base">
                            <i class="fas fa-info-circle flex-shrink-0"></i>Payment Instructions
                        </h3>
                        <ol class="text-xs sm:text-sm text-blue-800 space-y-1 sm:space-y-1.5">
                            <li><span class="font-bold mr-1">1.</span>Transfer <strong id="display-amount" class="text-blue-900"></strong> EGP to one of the numbers below.</li>
                            <li><span class="font-bold mr-1">2.</span>Take a clear screenshot of the successful transaction confirmation.</li>
                            <li><span class="font-bold mr-1">3.</span>Fill in the form and click <em>Next</em> to upload your screenshot.</li>
                        </ol>
                    </div>

                    <!-- Payment method boxes -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mb-5 sm:mb-6">
                        <div class="bg-gradient-to-br from-red-500 to-red-600 text-white rounded-xl p-4 sm:p-5">
                            <div class="flex items-center gap-3 mb-3">
                                <i class="fas fa-mobile-alt text-2xl sm:text-3xl flex-shrink-0"></i>
                                <div>
                                    <p class="font-bold text-base sm:text-lg">Vodafone Cash</p>
                                    <p class="text-xs opacity-80">Instant Transfer</p>
                                </div>
                            </div>
                            <div class="bg-white/20 rounded-lg p-2 sm:p-3 text-center">
                                <p class="text-xs opacity-75 mb-1">Transfer to:</p>
                                <p class="text-lg sm:text-2xl font-bold tracking-widest">01099429789</p>
                                <p class="text-xs opacity-75 mt-1">Name: Station Pro</p>
                            </div>
                        </div>
                        <div class="bg-gradient-to-br from-blue-500 to-blue-700 text-white rounded-xl p-4 sm:p-5">
                            <div class="flex items-center gap-3 mb-3">
                                <i class="fas fa-university text-2xl sm:text-3xl flex-shrink-0"></i>
                                <div>
                                    <p class="font-bold text-base sm:text-lg">InstaPay</p>
                                    <p class="text-xs opacity-80">Bank Transfer</p>
                                </div>
                            </div>
                            <div class="bg-white/20 rounded-lg p-2 sm:p-3 text-center">
                                <p class="text-xs opacity-75 mb-1">Transfer to:</p>
                                <p class="text-lg sm:text-2xl font-bold tracking-widest">01099429789</p>
                                <p class="text-xs opacity-75 mt-1">Name: Station Pro</p>
                            </div>
                        </div>
                    </div>

                    <!-- Form fields -->
                    <div class="mb-4 sm:mb-5">
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                            Payment Method Used <span class="text-red-500">*</span>
                        </label>
                        <select id="paymentMethod" required
                                class="w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm">
                            <option value="">— Select —</option>
                            <option value="VodafoneCash">Vodafone Cash</option>
                            <option value="InstaPay">InstaPay</option>
                        </select>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mb-4 sm:mb-5">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                Your Phone Number <span class="text-red-500">*</span>
                            </label>
                            <input type="tel" id="phoneNumber" required placeholder="01XXXXXXXXX"
                                   maxlength="11"
                                   class="w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 text-sm" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                Transaction Reference <span class="text-gray-400 font-normal text-xs">(optional)</span>
                            </label>
                            <input type="text" id="transactionRef" placeholder="e.g. VF123456"
                                   class="w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 text-sm" />
                        </div>
                    </div>

                    <div class="mb-5 sm:mb-6">
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                            Notes <span class="text-gray-400 font-normal text-xs">(optional)</span>
                        </label>
                        <textarea id="paymentNotes" rows="2" placeholder="Any additional info…"
                                  class="w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 text-sm resize-none"></textarea>
                    </div>

                    <!-- Buttons: side by side always, no wrapping -->
                    <div class="flex gap-3">
                        <button type="button" onclick="goToStep(1)"
                                class="flex-1 py-3 border-2 border-gray-300 text-gray-600 rounded-xl font-semibold text-sm hover:border-gray-400 transition-all whitespace-nowrap">
                            <i class="fas fa-arrow-left mr-1"></i>Back
                        </button>
                        <button type="button" onclick="goToStep(3)"
                                class="flex-1 py-3 bg-blue-600 text-white rounded-xl font-semibold text-sm hover:bg-blue-700 transition-all whitespace-nowrap">
                            Next <i class="fas fa-arrow-right ml-1"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- ════════════════════════════════════════════════════════════
                 STEP 3 — Upload Proof + Final Submit
                 ════════════════════════════════════════════════════════════ -->
            <div id="section-upload" class="hidden">
                <form asp-action="SubmitSubscription" asp-controller="Subscription"
                      method="post" enctype="multipart/form-data" id="subscriptionForm">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="TenantId" id="f-tenantId" value="@Model.TenantId" />
                    <input type="hidden" name="SubscriptionPlan" id="f-plan" />
                    <input type="hidden" name="Amount" id="f-amount" />
                    <input type="hidden" name="PaymentMethod" id="f-paymentMethod" />
                    <input type="hidden" name="PhoneNumber" id="f-phone" />
                    <input type="hidden" name="TransactionReference" id="f-txRef" />
                    <input type="hidden" name="Notes" id="f-notes" />

                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 sm:p-8 mb-6">
                        <h2 class="text-lg sm:text-2xl font-bold text-gray-900 mb-4 sm:mb-6">
                            <i class="fas fa-cloud-upload-alt text-blue-600 mr-2"></i>Upload Payment Proof
                        </h2>

                        <!-- Order summary -->
                        <div class="bg-gray-50 rounded-xl p-3 sm:p-4 mb-5 sm:mb-6 flex items-center justify-between">
                            <div>
                                <p class="text-xs text-gray-500 uppercase tracking-wide">Selected Plan</p>
                                <p class="font-bold text-gray-900 text-base sm:text-lg" id="summary-plan">—</p>
                            </div>
                            <div class="text-right">
                                <p class="text-xs text-gray-500 uppercase tracking-wide">Amount</p>
                                <p class="font-bold text-blue-600 text-base sm:text-lg"><span id="summary-amount">—</span> EGP/mo</p>
                            </div>
                        </div>

                        <!-- Drop zone -->
                        <div id="dropZone"
                             class="border-2 border-dashed border-gray-300 rounded-xl p-8 sm:p-10 text-center cursor-pointer hover:border-blue-400 hover:bg-blue-50/30 transition-all"
                             onclick="document.getElementById('fileInput').click()"
                             ondragover="event.preventDefault(); this.classList.add('border-blue-500','bg-blue-50')"
                             ondragleave="this.classList.remove('border-blue-500','bg-blue-50')"
                             ondrop="handleDrop(event)">
                            <i class="fas fa-cloud-upload-alt text-3xl sm:text-4xl text-gray-300 mb-2 sm:mb-3 block"></i>
                            <p class="text-gray-600 font-medium mb-1 text-sm">Click to upload or drag and drop</p>
                            <p class="text-xs text-gray-400">PNG, JPG up to 5 MB</p>
                            <input type="file" name="PaymentProof" id="fileInput"
                                   accept="image/png,image/jpeg,image/jpg" required class="hidden"
                                   onchange="handleFileSelect(this)" />
                        </div>

                        <!-- Preview — NO text under the image -->
                        <div id="previewArea" class="mt-4 hidden">
                            <div class="relative inline-block max-w-full">
                                <img id="previewImage" src="" alt="Payment proof"
                                     class="max-h-56 sm:max-h-64 rounded-xl border border-gray-200 shadow-sm" />
                                <button type="button" onclick="removeImage()"
                                        class="absolute top-2 right-2 w-7 h-7 bg-red-500 text-white rounded-full flex items-center justify-center text-xs hover:bg-red-600 transition-all">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>

                        <div class="flex gap-3 mt-5 sm:mt-6">
                            <button type="button" onclick="goToStep(2)"
                                    class="flex-1 py-3 border-2 border-gray-300 text-gray-600 rounded-xl font-semibold text-sm hover:border-gray-400 transition-all whitespace-nowrap">
                                <i class="fas fa-arrow-left mr-1"></i>Back
                            </button>
                            <button type="submit" id="submitBtn"
                                    class="flex-1 py-3 bg-green-600 text-white rounded-xl font-semibold text-sm hover:bg-green-700 transition-all flex items-center justify-center gap-1.5 whitespace-nowrap">
                                <i class="fas fa-check"></i>Submit
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <footer class="bg-white border-t py-4 sm:py-5 mt-6 sm:mt-8">
        <div class="max-w-7xl mx-auto px-4 text-center text-xs sm:text-sm text-gray-400">
            © 2026 Station Pro. All rights reserved.
        </div>
    </footer>

    <script src="~/js/subscribe.js"></script>
</body>
</html>
